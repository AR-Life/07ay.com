---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sayfa Bulunamadı - 404 | 07 AY Dijital Ajans" description="Aradığınız sayfa bulunamadı. Lütfen ana sayfaya dönün.">
  <main class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden">
    <!-- Background Effects -->
    <div class="stars-bg absolute inset-0"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-cosmic-purple/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="container relative z-10 mx-auto px-4 text-center">
      <div class="glass-heavy p-12 max-w-2xl mx-auto rounded-3xl border border-white/10 relative overflow-hidden">
        <!-- Glow accent -->
        <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-transparent via-gold-500 to-transparent opacity-50"></div>
        
        <h1 class="text-9xl font-black gradient-gold mb-6 tracking-tighter">404</h1>
        <h2 class="text-3xl font-bold text-white mb-6">Kayboldunuz Sanırım!</h2>
        <p class="text-text-secondary text-lg mb-10 max-w-md mx-auto">
          Aradığınız sayfayı bulamadık. Ya link hatalı ya da sayfa artık aramızda değil.
        </p>
        
        <a href="/" title="Ana Sayfaya Dön" class="btn-primary inline-flex">
          Ana Sayfaya Dön
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
