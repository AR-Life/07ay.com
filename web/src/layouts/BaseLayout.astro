} = Astro.props;

// FAQ data for Schema (must match FAQSection.astro content exactly)
const faqSchemaItems = [
  {
    question: "Antalya'da en iyi web tasarım firması hangisi?",
    answer: "Antalya'da en iyi web tasarım firması seçerken hız, SEO uyumu ve modern tasarım kriterlerine dikkat etmelisiniz. 07 AY Dijital Ajans, Google PageSpeed testlerinde 100/100 performans sağlayan, mobil uyumlu ve SEO altyapılı kurumsal web siteleri tasarlayan Antalya merkezli profesyonel bir web tasarım ajansıdır. WordPress gibi hantal altyapılar yerine, dünya standartlarında modern teknolojiler (Astro, Tailwind CSS, Cloudflare) kullanarak işletmenize özel, hızlı ve güvenli siteler üretiyoruz.",
  },
  {
    question: "Antalya web sitesi yaptırmanın maliyeti ne kadar?",
    answer: "Antalya'da web sitesi yaptırma maliyeti, projenin kapsamına göre değişir. Tek sayfalık tanıtım siteleri, çok sayfalık kurumsal siteler ve e-ticaret siteleri farklı fiyat aralıklarına sahiptir. 07 AY olarak şeffaf fiyatlandırma politikamızla, sürpriz maliyetler çıkarmadan, işletmenizin bütçesine uygun çözümler sunuyoruz. Ücretsiz analiz ve fiyat teklifi almak için WhatsApp hattımızdan bize ulaşabilirsiniz.",
  },
  {
    question: "SEO çalışması ne kadar sürede sonuç verir?",
    answer: "Profesyonel SEO çalışması genellikle 3-6 ay içinde somut sonuçlar vermeye başlar. Ancak bu süre, sektörünüzdeki rekabet düzeyine, hedeflenen anahtar kelimelere ve mevcut sitenizin durumuna bağlıdır. 07 AY olarak Antalya yerel SEO stratejileriyle, Google Haritalar ve organik arama sonuçlarında işletmenizin görünürlüğünü artırıyoruz. Yerel (GEO) odaklı çalışmalarımız sayesinde Antalya bölgesinde daha hızlı sonuç almanız mümkündür.",
  },
  {
    question: "Sosyal medya yönetimi hizmetiniz neleri kapsar?",
    answer: "Antalya sosyal medya yönetimi hizmetimiz; Instagram, Facebook, TikTok ve LinkedIn için profesyonel içerik üretimi, post ve reel tasarımları, hashtag stratejisi, takipçi etkileşim yönetimi, reklam kampanyaları ve aylık performans raporlarını kapsar. Markanızın sosyal medyada güçlü bir varlık oluşturmasını sağlıyoruz. İçerik takvimi hazırlama, rakip analizi ve hedef kitle belirleme de dahildir.",
  },
  {
    question: "Neden profesyonel bir dijital ajansla çalışmalıyım?",
    answer: "Profesyonel bir dijital ajansla çalışmak, zamanınızı ve bütçenizi verimli kullanmanızı sağlar. Amatör çözümler kısa vadede ucuz görünse de, SEO uyumsuz siteler Google'da görünmez, kalitesiz sosyal medya içerikleri müşteri kaybettirir. 07 AY Dijital Ajans olarak stratejik planlama, profesyonel tasarım, teknik SEO ve veri odaklı raporlama ile yatırımınızın karşılığını fazlasıyla almanızı sağlıyoruz.",
  },
  {
    question: "Google Ads ile organik SEO arasındaki fark nedir?",
    answer: "Google Ads (ücretli reklam), bütçe ayırdığınız sürece anında üst sıralarda görünmenizi sağlar. Organik SEO ise uzun vadeli bir yatırımdır; doğru yapıldığında sürekli ve ücretsiz trafik getirir. 07 AY olarak her iki stratejiyi de birlikte uyguluyoruz: kısa vadede Google Ads ile hemen müşteri kazanırken, uzun vadede organik SEO ile kalıcı sonuçlar elde ediyoruz. Antalya bölgesinde her iki alanda da uzman ekibimizle sonuç odaklı çalışıyoruz.",
  },
  {
    question: "Antalya'da e-ticaret sitesi kurmak ne kadar sürer?",
    answer: "Antalya'da profesyonel bir e-ticaret sitesi kurulumu, projenin kapsamına bağlı olarak 2-6 hafta sürer. Ürün sayısı, ödeme entegrasyonları, kargo firması entegrasyonları ve özel tasarım istekleri süreyi etkiler. 07 AY olarak Trendyol, Hepsiburada gibi pazar yeri entegrasyonları da dahil olmak üzere komple e-ticaret çözümleri sunuyoruz. SEO uyumlu altyapısı sayesinde Google'da görünürlüğünüz en üst düzeyde olur.",
  },
  {
    question: "Logo tasarımı süreci nasıl işler?",
    answer: "Logo ve marka kimliği tasarım sürecimiz 4 adımdan oluşur: İlk olarak markanızı, sektörünüzü ve hedef kitlenizi analiz ediyoruz. Ardından 3-5 farklı konsept tasarım sunuyoruz. Seçtiğiniz konsept üzerinde revizyonlar yapıp mükemmelleştiriyoruz. Son olarak logonuzu tüm formatlarda (vektörel, PNG, favicon) teslim ediyoruz. Kurumsal kimlik paketi; kartvizit, antetli kağıt, sosyal medya kit ve brand guideline'ı kapsar.",
  },
  {
    question: "Dijital reklam bütçemi nasıl belirlemeliyim?",
    answer: "Dijital reklam bütçesi, sektörünüze, hedeflerinize ve rekabet düzeyine göre belirlenir. Antalya'da yerel bir işletme için Google Ads ve Meta (Instagram/Facebook) reklamlarında optimum sonuçlar almak mümkündür. 07 AY olarak reklam bütçenizi en verimli şekilde kullanıyoruz; A/B testleri, hedef kitle optimizasyonu ve detaylı dönüşüm raporları ile her kuruşun karşılığını almanızı sağlıyoruz.",
  },
  {
    question: "Hangi sosyal medya platformu işletmem için en uygun?",
    answer: "En uygun sosyal medya platformu, işletmenizin sektörüne ve hedef kitlesine bağlıdır. Restoran, otel ve güzellik sektörü için Instagram ve TikTok; B2B hizmetler için LinkedIn; genel tüketici ürünleri için Facebook ve Instagram öne çıkar. 07 AY Dijital Ajans olarak Antalya'daki işletmeniz için en etkili platform stratejisini belirliyor, içerik üretiminden reklam yönetimine kadar tüm süreci profesyonelce yönetiyoruz.",
  },
];
