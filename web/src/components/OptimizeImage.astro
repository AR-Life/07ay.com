---
// src/components/OptimizedImage.astro
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  sizes?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  class: className = "",
  sizes = "(max-width: 480px) 100vw, (max-width: 768px) 450px, 640px", 
  loading = "lazy",
  fetchpriority = "auto",
  width,
  height,
} = Astro.props;

// Lighthouse'un tam istediği o nokta atışı ara kesit pikselleri
const pageSpeedWidths = [240, 320, 360, 380, 420, 480, 500, 540, 600, 640, 660, 720, 768, 1024, 1280];
---

<Picture
  src={src}
  alt={alt}
  widths={pageSpeedWidths}
  sizes={sizes}
  formats={['avif', 'webp']}
  fallbackFormat="webp"
  quality={55}
  loading={loading}
  fetchpriority={fetchpriority}
  class={className}
  width={width || src.width}  
  height={height || src.height} 
/>