---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: "Hizmetler", href: "#hizmetler" },
  { label: "Neden Biz?", href: "#neden-biz" },
  { label: "Sektörler", href: "#sektorler" },
  { label: "Yorumlar", href: "#yorumlar" },
];

const services = [
  "Google SEO & Reklam",
  "Sosyal Medya Yönetimi",
  "Web Sitesi Tasarımı",
  "Logo & Marka Kimliği",
  "Video & Fotoğraf",
  "E-Ticaret Çözümleri",
];
---

<footer id="iletisim" class="relative pt-20 pb-8 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-night-900 to-night-950"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[200px] bg-gold-500/3 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 pb-12 border-b border-white/5">
      <!-- Logo & About -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg width="32" height="32" viewBox="0 0 40 40" fill="none">
            <defs>
              <linearGradient id="moonGradFooter" x1="4" y1="4" x2="36" y2="36">
                <stop stop-color="#f5d77a" />
                <stop offset="1" stop-color="#d4a843" />
              </linearGradient>
              <mask id="moonMaskFooter">
                <rect width="40" height="40" fill="white" />
                <circle cx="26" cy="16" r="10" fill="black" />
              </mask>
            </defs>
            <circle cx="20" cy="20" r="16" fill="url(#moonGradFooter)" mask="url(#moonMaskFooter)" opacity="0.9" />
          </svg>
          <span class="text-xl font-extrabold text-white">07 <span class="gradient-gold">AY</span></span>
        </a>
        <p class="text-sm text-text-muted leading-relaxed mb-6">
          İşletmelerin dijital dünyada büyümesini sağlayan 360° dijital ajans. Strateji, yaratıcılık ve teknoloji bir arada.
        </p>
        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          <a href="#" class="w-9 h-9 rounded-lg glass flex items-center justify-center text-text-muted hover:text-white hover:bg-white/10 transition-all duration-200" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-lg glass flex items-center justify-center text-text-muted hover:text-white hover:bg-white/10 transition-all duration-200" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-lg glass flex items-center justify-center text-text-muted hover:text-white hover:bg-white/10 transition-all duration-200" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-lg glass flex items-center justify-center text-text-muted hover:text-white hover:bg-white/10 transition-all duration-200" aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Hızlı Linkler</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-gold-400 transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Hizmetler</h3>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <span class="text-sm text-text-muted">{service}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">İletişim</h3>
        <ul class="space-y-4">
          <li>
            <a href="https://wa.me/905439402019" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-text-muted hover:text-green-400 transition-colors duration-200">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              0543 940 20 19
            </a>
          </li>
          <li>
            <a href="tel:+905307702435" class="flex items-center gap-3 text-sm text-text-muted hover:text-gold-400 transition-colors duration-200">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              0530 770 24 35
            </a>
          </li>
          <li>
            <div class="flex items-center gap-3 text-sm text-text-muted">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              Antalya, Türkiye
            </div>
          </li>
          <li>
            <a href="https://07ay.com" class="flex items-center gap-3 text-sm text-text-muted hover:text-gold-400 transition-colors duration-200">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              07ay.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-muted">
        © {currentYear} 07 AY Dijital Ajans. Tüm hakları saklıdır.
      </p>
      <p class="text-xs text-text-muted">
        Antalya'dan 🌙 ile yapıldı.
      </p>
    </div>
  </div>
</footer>
