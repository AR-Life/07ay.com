---
const sectors = [
  { icon: "🏪", name: "Esnaf & Mağaza", desc: "Antalya esnaf web sitesi" },
  { icon: "🏠", name: "Emlak & Gayrimenkul", desc: "Antalya emlak web sitesi" },
  { icon: "🚗", name: "Oto Galeri", desc: "Antalya oto galeri web sitesi" },
  { icon: "🍽️", name: "Restoran & Kafe", desc: "Antalya restoran web sitesi" },
  { icon: "🏨", name: "Otel & Pansiyon", desc: "Antalya otel web sitesi" },
  { icon: "🏥", name: "Klinik & Hastane", desc: "Antalya klinik web sitesi" },
  { icon: "💇", name: "Kuaför & Berber", desc: "Antalya kuaför web sitesi" },
  { icon: "🔧", name: "Usta & Servis", desc: "Antalya usta web sitesi" },
  { icon: "🏗️", name: "İnşaat & Mimarlık", desc: "Antalya inşaat web sitesi" },
  { icon: "📚", name: "Eğitim & Kurs", desc: "Antalya eğitim web sitesi" },
  { icon: "⚖️", name: "Avukat & Hukuk", desc: "Antalya avukat web sitesi" },
  { icon: "🦷", name: "Diş Hekimi", desc: "Antalya diş hekimi web sitesi" },
  { icon: "💊", name: "Eczane & Sağlık", desc: "Antalya eczane web sitesi" },
  { icon: "🏋️", name: "Spor Salonu", desc: "Antalya spor salonu web sitesi" },
  { icon: "🌸", name: "Güzellik Salonu", desc: "Antalya güzellik web sitesi" },
  { icon: "✨", name: "Ve Daha Fazlası", desc: "Tüm sektörler" },
];
---

<section id="sektorler" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-night-800 to-night-900"></div>
  <div class="absolute top-1/2 right-0 w-96 h-96 bg-cosmic-purple/5 rounded-full blur-[128px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="reveal inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-6">
        <span class="text-sm text-gold-400">Sektörler</span>
      </div>
      <h2 class="reveal reveal-delay-1 section-title mb-4">
        Antalya'da Hizmet Verdiğimiz
        <span class="gradient-gold">Sektörler</span>
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        Antalya'da her sektöre özel <strong>web tasarım</strong>, <strong>SEO</strong> ve <strong>dijital pazarlama</strong> çözümleri sunuyoruz. Hangi sektörde olursanız olun — otel, restoran, klinik, avukat veya esnaf — dijital dünyadaki yerinizi birlikte oluşturalım.
      </p>
    </div>

    <!-- Sectors Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-4">
      {
        sectors.map((sector, i) => (
          <div class={`reveal reveal-delay-${(i % 5) + 1} glass-card p-4 text-center group cursor-default`} title={sector.desc}>
            <div class="text-3xl mb-2 transition-transform duration-300 group-hover:scale-125">
              {sector.icon}
            </div>
            <span class="text-xs font-medium text-text-secondary group-hover:text-white transition-colors duration-300">
              {sector.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
