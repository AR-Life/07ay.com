---
const navLinks = [
  { label: "Hakkımızda", href: "#hakkimizda" },
  { label: "Hizmetler", href: "#hizmetler" },
  { label: "Portfolyo", href: "#portfolyo" },
  { label: "Neden Biz?", href: "#neden-biz" },
  { label: "Sektörler", href: "#sektorler" },
  { label: "İletişim", href: "#iletisim" },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" title="07 AY Ana Sayfa" class="flex items-center gap-2 group">
        <div class="relative">
          <svg
            width="40"
            height="40"
            viewBox="0 0 40 40"
            fill="none"
            class="transition-transform duration-300 group-hover:scale-110"
          >
            <defs>
              <linearGradient id="moonGrad" x1="4" y1="4" x2="36" y2="36">
                <stop stop-color="#f5d77a"></stop>
                <stop offset="1" stop-color="#d4a843"></stop>
              </linearGradient>
              <mask id="moonMask">
                <rect width="40" height="40" fill="white"></rect>
                <circle cx="26" cy="16" r="10" fill="black"></circle>
              </mask>
            </defs>
            <circle
              cx="20"
              cy="20"
              r="16"
              fill="url(#moonGrad)"
              mask="url(#moonMask)"
              opacity="0.9"></circle>
          </svg>
        </div>
        <span class="text-2xl font-extrabold text-white tracking-tight">
          07 <span class="gradient-gold">AY</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              title={link.label}
              class="text-sm font-medium text-text-secondary hover:text-white transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- CTA Button -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href="https://wa.me/905307702435?text=Merhaba%2C%20bilgi%20almak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          title="WhatsApp'tan İletişime Geçin"
          class="btn-primary text-sm"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          WhatsApp'tan Yazın
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menüyü aç"
        aria-expanded="false"
      >
        <span
          class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center"
          id="bar1"></span>
        <span
          class="block w-6 h-0.5 bg-white transition-all duration-300"
          id="bar2"></span>
        <span
          class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center"
          id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden absolute top-full left-0 right-0 bg-night-900 backdrop-blur-xl border-t border-white/5 shadow-2xl"
  >
    <div class="px-4 py-6 flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            title={link.label}
            class="mobile-nav-link text-lg font-medium text-text-secondary hover:text-white transition-colors duration-200 py-2"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://wa.me/905307702435?text=Merhaba%2C%20bilgi%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        title="WhatsApp'tan İletişime Geçin"
        class="btn-primary text-center justify-center mt-2"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        WhatsApp'tan Yazın
      </a>
    </div>
  </div>
</header>

<script>
  {
    // Header scroll effect
    const header = document.getElementById("header");
    let ticking = false;
    let menuOpen = false;

    const updateHeaderBackground = () => {
      if (window.scrollY > 50 || menuOpen) {
        header?.classList.add(
          "bg-night-900/95",
          "backdrop-blur-xl",
          "border-b",
          "border-white/5",
        );
      } else {
        header?.classList.remove(
          "bg-night-900/95",
          "backdrop-blur-xl",
          "border-b",
          "border-white/5",
        );
      }
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateHeaderBackground();
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true },
    );

    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const bar1 = document.getElementById("bar1");
    const bar2 = document.getElementById("bar2");
    const bar3 = document.getElementById("bar3");

    mobileMenuBtn?.addEventListener("click", () => {
      menuOpen = !menuOpen;
      mobileMenu?.classList.toggle("hidden");
      mobileMenuBtn?.setAttribute("aria-expanded", String(menuOpen));

      updateHeaderBackground();

      if (menuOpen) {
        bar1?.classList.add("rotate-45", "translate-y-2");
        bar2?.classList.add("opacity-0");
        bar3?.classList.add("-rotate-45", "-translate-y-2");
      } else {
        bar1?.classList.remove("rotate-45", "translate-y-2");
        bar2?.classList.remove("opacity-0");
        bar3?.classList.remove("-rotate-45", "-translate-y-2");
      }
    });

    // Close mobile menu on link click
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu?.classList.add("hidden");
        menuOpen = false;
        mobileMenuBtn?.setAttribute("aria-expanded", "false");
        bar1?.classList.remove("rotate-45", "translate-y-2");
        bar2?.classList.remove("opacity-0");
        bar3?.classList.remove("-rotate-45", "-translate-y-2");
        updateHeaderBackground();
      });
    });
  }
</script>
