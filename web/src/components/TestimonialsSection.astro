---
const testimonials = [
  {
    name: "Fazıl Yiğit",
    sector: "Otomotiv — FZL Otomotiv",
    rating: 5,
    text: "Antalya'da web sitemizi 07 AY ile yaptırdık, SEO çalışmalarıyla Google'da çok iyi konumlara geldik. Artık müşteriler bizi 'Antalya oto galeri' diye aratınca hemen buluyor. Web tasarım ve SEO yatırımımızın karşılığını fazlasıyla aldık.",
    avatar: "F",
  },
  {
    name: "Erol Özcan",
    sector: "Sağlık Turizmi — MediBelieve",
    rating: 5,
    text: "Sağlık turizmi alanındaki web projemiz için 07 AY Dijital Ajans ile çalıştık. Çok dilli, hızlı ve SEO uyumlu altyapı sayesinde yurtdışından gelen hasta taleplerimiz gözle görülür şekilde arttı. Profesyonel ekip, zamanında teslimat.",
    avatar: "E",
  },
  {
    name: "Afranur Kaşlı",
    sector: "Diyetisyen — Fethiye",
    rating: 5,
    text: "Bölgesel SEO odaklı ve şık kişisel web sitem sayesinde kendi bölgemdeki danışanlarıma çok daha kolay ulaşıyorum. 07 AY'ın web tasarım ve yerel SEO hizmetinden çok memnunum, sürecin her adımında profesyonellerdi.",
    avatar: "A",
  },
];
---

<section id="yorumlar" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-night-900 via-night-800 to-night-900"
  >
  </div>
  <div
    class="absolute top-0 left-1/3 w-96 h-96 bg-gold-500/5 rounded-full blur-[200px] pointer-events-none"
  >
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div
        class="reveal inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-6"
      >
        <span class="text-sm text-gold-400">Müşteri Yorumları</span>
      </div>
      <h2 class="reveal reveal-delay-1 section-title mb-4">
        Antalya'daki Müşterilerimiz
        <span class="gradient-gold">Ne Diyor?</span>
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        <strong>07 AY Dijital Ajans</strong> ile çalışan Antalya'daki işletme sahiplerinin
        web tasarım, SEO ve dijital reklam deneyimleri.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        testimonials.map((t, i) => (
          <div
            class={`reveal reveal-delay-${(i % 3) + 1} glass-card p-6 flex flex-col`}
          >
            {/* Stars */}
            <div class="flex gap-1 mb-4">
              {Array.from({ length: t.rating }).map(() => (
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="#d4a843"
                  stroke="none"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>

            {/* Text */}
            <p class="text-text-secondary text-sm leading-relaxed mb-6 flex-1">
              "{t.text}"
            </p>

            {/* Author */}
            <div class="flex items-center gap-3 pt-4 border-t border-white/5">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold-500 to-gold-300 flex items-center justify-center text-night-900 font-bold text-sm">
                {t.avatar}
              </div>
              <div>
                <p class="text-sm font-semibold text-white">{t.name}</p>
                <p class="text-xs text-text-muted">{t.sector}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
