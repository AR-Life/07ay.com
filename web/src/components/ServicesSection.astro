---
const services = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title: "Google'da Üst Sıralara Çıkın",
    description: "Müşterileriniz sizi aradığında Google'da ilk sayfada görünün. SEO ve Google Ads ile anında sonuç alın.",
    color: "from-blue-500 to-cyan-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: "Profesyonel Web Sitesi",
    description: "Modern, hızlı ve mobil uyumlu web sitenizi tasarlıyoruz. İlk izlenim her şeydir.",
    color: "from-purple-500 to-pink-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
    title: "Sosyal Medya Yönetimi",
    description: "Instagram, Facebook ve TikTok hesaplarınızı profesyonelce yönetiyoruz. İçerik üretiminden reklama kadar.",
    color: "from-pink-500 to-rose-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    title: "Logo & Marka Kimliği",
    description: "İşletmenizi yansıtan profesyonel logo ve kurumsal kimlik tasarımları yapıyoruz.",
    color: "from-amber-500 to-orange-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
    title: "Video & Fotoğraf Çekimi",
    description: "Tanıtım videoları, ürün fotoğrafları ve sosyal medya içerikleri ile markanızı öne çıkarın.",
    color: "from-emerald-500 to-teal-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "WhatsApp ile Müşteri Kazanın",
    description: "WhatsApp Business kurulumu ve reklamları ile doğrudan müşterilerinize ulaşın.",
    color: "from-green-500 to-emerald-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>`,
    title: "Dijital Reklam Yönetimi",
    description: "Google, Instagram, YouTube ve TikTok reklamlarınızı yönetiyor, raporluyoruz.",
    color: "from-indigo-500 to-blue-400",
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="12" cy="15" r="1"/></svg>`,
    title: "E-Ticaret Çözümleri",
    description: "Online satış sitenizi kuruyor, Trendyol ve Hepsiburada entegrasyonlarınızı yapıyoruz.",
    color: "from-violet-500 to-purple-400",
  },
];
---

<section id="hizmetler" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-night-900 via-night-800 to-night-900"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-cosmic-blue/5 rounded-full blur-[128px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="reveal inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-6">
        <span class="text-sm text-gold-400">Hizmetlerimiz</span>
      </div>
      <h2 class="reveal reveal-delay-1 section-title mb-4">
        İşletmenizi Büyütecek
        <span class="gradient-gold">Çözümler</span>
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        Dijital dünyada fark yaratmanız için ihtiyacınız olan tüm hizmetleri tek çatı altında sunuyoruz.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        services.map((service, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} glass-card p-6 group cursor-default`}>
            {/* Icon */}
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${service.color} flex items-center justify-center mb-5 text-white transition-transform duration-300 group-hover:scale-110`}>
              <Fragment set:html={service.icon} />
            </div>

            {/* Title */}
            <h3 class="text-lg font-bold text-white mb-3 group-hover:text-gold-400 transition-colors duration-300">
              {service.title}
            </h3>

            {/* Description */}
            <p class="text-sm text-text-secondary leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="reveal text-center mt-12">
      <p class="text-text-muted mb-4">Tüm hizmetlerimizi detaylı görmek ister misiniz?</p>
      <a
        href="https://wa.me/905439402019?text=Merhaba%2C%20hizmetleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        Detaylı Bilgi Alın →
      </a>
    </div>
  </div>
</section>
