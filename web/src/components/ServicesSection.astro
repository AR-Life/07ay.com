---

<section id="hizmetler" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-night-900 via-night-800 to-night-900"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-cosmic-blue/5 rounded-full blur-[128px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="reveal inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-6">
        <span class="text-sm text-gold-400">Hizmetlerimiz</span>
      </div>
      <h2 class="reveal reveal-delay-1 section-title mb-4">
        Antalya'da İşletmenizi Büyütecek
        <span class="gradient-gold">Dijital Ajans Hizmetleri</span>
      </h2>
      <p class="reveal reveal-delay-2 section-subtitle mx-auto">
        <strong>Antalya web tasarım</strong>, <strong>yerel SEO danışmanlığı</strong>, <strong>sosyal medya yönetimi</strong>, <strong>Google Ads reklam yönetimi</strong> ve <strong>e-ticaret çözümleri</strong> — dijital dünyada fark yaratmanız için ihtiyacınız olan tüm profesyonel ajans hizmetlerini tek çatı altında sunuyoruz.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        services.map((service, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} glass-card p-6 group cursor-default`}>
            {/* Icon */}
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${service.color} flex items-center justify-center mb-5 text-white transition-transform duration-300 group-hover:scale-110`}>
              <Fragment set:html={service.icon} />
            </div>

            {/* Title */}
            <h3 class="text-lg font-bold text-white mb-3 group-hover:text-gold-400 transition-colors duration-300">
              {service.title}
            </h3>

            {/* Description */}
            <p class="text-sm text-text-secondary leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="reveal text-center mt-12">
      <p class="text-text-muted mb-4">Tüm Antalya dijital ajans hizmetlerimizi detaylı görmek ister misiniz?</p>
      <a
        href="https://wa.me/905307702435?text=Merhaba%2C%20hizmetleriniz%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum."
        target="_blank"
        title="Antalya Dijital Ajans Hizmetleri Bilgi Hattı"
        rel="noopener noreferrer nofollow"
        class="btn-secondary"
      >
        Detaylı Bilgi Alın →
      </a>
    </div>
  </div>
</section>
